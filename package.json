    "@vitest/coverage-v8": "^4.1.2",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.0.1",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3",
    "react": "^19.2.0",
    "react-diff-view": "^3.3.2",
    "react-dom": "^19.2.0",
